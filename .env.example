# Velocity White Papers — local authoring secrets.
#
# Copy this file to ".env" in this same Whitepaper/ directory and fill in the
# real values. The .env file is gitignored and must never be committed. The
# loader (app/site/scripts/lib/env.mjs) reads Whitepaper/.env first, then an
# optional app/site/.env override.
#
# These keys are needed for the dev-only editor (npm run edit) and the
# generation scripts (generate:images, generate:audio, translate). The public
# site does not use any of them; it is static.

# ---- Claude on Google Vertex (drafting, revising, translating) ----
# The full service-account JSON as a single line. Keep the embedded \n escapes
# in private_key. Example: {"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com", ...}
VERTEX_SERVICE_ACCOUNT_JSON=
VERTEX_PROJECT_ID=
# Optional, these have sensible defaults if omitted:
VERTEX_LOCATION_ID=global
VERTEX_ENDPOINT=aiplatform.googleapis.com
VERTEX_METHOD=rawPredict
VERTEX_CLAUDE_SONNET_MODEL=claude-sonnet-4-6
VERTEX_CLAUDE_OPUS_MODEL=claude-opus-4-8

# ---- OpenAI (image generation) ----
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1

# ---- ElevenLabs (narration audio) ----
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_64
# Seconds of pause inserted between sentences for a calmer narration cadence.
# Set to 0 to disable. Narration is generated one paragraph per call and the
# clips are concatenated, so this stays well clear of ElevenLabs' break-tag limit.
ELEVENLABS_SENTENCE_PAUSE=0.4

# ---- Local server (optional) ----
# PORT=5173
# VW_EDIT=1   # alternative to the --enable flag for turning the editor on
